{
  "manifest_version": 3,
  "name": "ClaimRail Auto-Register",
  "version": "1.0.0",
  "description": "Auto-fill BMI work registration forms with ClaimRail metadata.",
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://www.bmi.com/*",
    "https://claim-rail.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.bmi.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
